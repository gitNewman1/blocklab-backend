generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Model {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  modelTypeId  Int?     @map("model_type_id")
  thumbnailUrl String?  @map("thumbnail_url")
  manualUrl    String?  @map("manual_url")
  ioFileUrl    String   @map("io_file_url")
  model3dUrl   String   @map("model_3d_url")
  partCount    Int      @default(0) @map("part_count")
  partsJson    Json     @map("parts_json")
  stepsJson    Json     @map("steps_json")
  createdAt    DateTime @default(now()) @map("created_at")
  modelType    ModelType? @relation(fields: [modelTypeId], references: [id])

  @@map("models")
  @@index([createdAt(sort: Desc)])
  @@index([modelTypeId])
}

model User {
  id        String   @id @default(uuid())
  unionId   String   @unique @map("union_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model ModelType {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  models    Model[]

  @@map("model_types")
  @@index([createdAt(sort: Desc)])
}
