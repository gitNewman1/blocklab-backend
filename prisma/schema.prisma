generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Model {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  modelTypeId  Int?     @map("model_type_id")
  thumbnailUrl String?  @map("thumbnail_url")
  manualUrl    String?  @map("manual_url")
  ioFileUrl    String   @map("io_file_url")
  model3dUrl   String   @map("model_3d_url")
  partCount    Int      @default(0) @map("part_count")
  partsJson    Json     @map("parts_json")
  stepsJson    Json     @map("steps_json")
  createdAt    DateTime @default(now()) @map("created_at")
  modelType    ModelType? @relation(fields: [modelTypeId], references: [id])

  @@map("models")
  @@index([createdAt(sort: Desc)])
  @@index([modelTypeId])
}

model User {
  id          String     @id @default(uuid())
  unionId     String     @unique @map("union_id")
  nickname    String?    @db.VarChar(100)
  scanCount   Int        @default(0) @map("scan_count")
  createdAt   DateTime   @default(now()) @map("created_at")
  works       Work[]
  likesGiven  WorkLike[]

  @@map("users")
}

enum WorkCategory {
  TECHNOLOGY
  VEHICLE
  FOOD
  ANIMAL
  ARCHITECTURE
  OTHER
}

model Work {
  id            Int          @id @default(autoincrement())
  userId        String       @map("user_id")
  imageUrl      String       @map("image_url")
  name          String       @db.VarChar(100)
  category      WorkCategory @default(OTHER)
  partCount     Int?         @map("part_count")
  description   String
  tags          String[]
  generate3d    Boolean      @default(false) @map("generate_3d")
  hunyuan3dTaskId String?    @map("hunyuan3d_task_id")
  hunyuan3dStatus String?    @map("hunyuan3d_status")
  model3dUrl      String?    @map("model_3d_url")
  isPublic      Boolean      @default(true) @map("is_public")
  joinContest   Boolean      @default(false) @map("join_contest")
  createdAt     DateTime     @default(now()) @map("created_at")
  user          User         @relation(fields: [userId], references: [id])
  likes         WorkLike[]

  @@map("works")
  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model WorkLike {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  workId    Int      @map("work_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])
  work      Work     @relation(fields: [workId], references: [id])

  @@unique([userId, workId])
  @@map("work_likes")
  @@index([workId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model RecommendedModel {
  id          Int      @id @default(autoincrement())
  setNumber   String   @map("set_number") @db.VarChar(20)
  name        String   @db.VarChar(100)
  series      String?  @db.VarChar(50)
  partCount   Int      @map("part_count")
  price       Decimal  @db.Decimal(10, 2)
  ageRating   String?  @map("age_rating") @db.VarChar(10)
  description String?
  coverUrl    String   @map("cover_url")
  displayUrl  String   @map("display_url")
  detailUrls  String[] @map("detail_urls")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("recommended_models")
  @@index([createdAt(sort: Desc)])
}

model ModelType {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  models    Model[]

  @@map("model_types")
  @@index([createdAt(sort: Desc)])
}
