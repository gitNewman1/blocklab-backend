# Database
DATABASE_URL="postgresql://blocklab_user:your_password@localhost:5432/blocklab"

# Server
PORT=3000
NODE_ENV=development

# Local file storage
UPLOAD_ROOT="./uploads"
PUBLIC_BASE_URL="http://localhost:3000"
MAX_FILE_SIZE_MB=50

# Rebrickable API
REBRICKABLE_API_KEY=""
REBRICKABLE_BASE_URL="https://rebrickable.com/api/v3"
REBRICKABLE_TIMEOUT_MS=8000
REBRICKABLE_BATCH_SIZE=80

# Roboflow workflow
ROBOFLOW_API_KEY=""
ROBOFLOW_WORKFLOW_URL=""
ROBOFLOW_TIMEOUT=15000
